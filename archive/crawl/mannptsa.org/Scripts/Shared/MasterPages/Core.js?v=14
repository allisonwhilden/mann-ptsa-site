// Arguments are image paths relative to the current page.
function preLoadImages()
{
    var args_len = arguments.length;
    for (var i = args_len; i--; )
    {
        var cacheImage = document.createElement('img');
        cacheImage.src = arguments[i];
        cache.push(cacheImage);
    }
}

function textAreaUseMarkdown(textValue) {
    return textValue && textValue.substr(0, "usemarkdown".length).toLowerCase() === "usemarkdown";
}

// Position popup appropriately relative to another control.
function displayPopup($hoverDiv, $relativeTo, leftOffset, topOffset) {

    var $hoverParentDiv = $relativeTo;
    var $positionedRelativeDiv = $hoverDiv.parents(".PositionRelative").first();

    var parentLeftPosition = $hoverParentDiv.offset().left - $positionedRelativeDiv.offset().left;
    var parentTopPosition = $hoverParentDiv.offset().top - $positionedRelativeDiv.offset().top;

    $hoverDiv.css('left', (parentLeftPosition + leftOffset) + 'px');
    $hoverDiv.css('top', (parentTopPosition + topOffset) + 'px');

    $hoverDiv.fadeIn('fast');
}

// Position popup appropriately relative to parent.
function displayHoverDiv(hoverDiv)
{
    var $hoverDiv = $(hoverDiv);
    var $hoverParentDiv = $hoverDiv.parent();
    var $hoverRelativeToParentDiv = $hoverDiv.parents(".PositionRelative").first();

    var parentLeftPosition = $hoverParentDiv.offset().left - $hoverRelativeToParentDiv.offset().left;
    var parentTopPosition = $hoverParentDiv.offset().top - $hoverRelativeToParentDiv.offset().top;

    // Position the callout relative to its parent.  If the parent's absolute
    // position is less than 500, put the callout to the right of the parent.
    // Otherwise put the callout to the left of the parent.
    if ($hoverParentDiv.offset().left < 500)
    {
        $hoverDiv.css('left', (parentLeftPosition + $hoverParentDiv.width() - 10) + 'px');
    }
    else
    {
        $hoverDiv.css('left', (parentLeftPosition - $hoverDiv.width() + 10) + 'px');
    }

    $hoverDiv.css('top', (parentTopPosition - ($hoverDiv.height() / 2)) + 'px');

    $hoverDiv.show();
}

function InitializeCore(scope)
{
    $(".FullBox, .HalfBox", scope).each(function ()
    {
        var title = $(this).attr("data-HeaderText");
        if (title == undefined)
        {
            title = "";
        }

        if (title.length == 0)
        {
            var $headerDiv = $("<div class='NoHeader'>&nbsp;</div>");
        }
        else
        {
            var $headerDiv = $("<div class='OuterBoxHeader'><div class='InnerBoxHeader'>" + title + "</div></div>");
        }

        $(this).prepend($headerDiv);
    });

    $(".AdminDeleteButton", scope).click(function ()
    {
        return confirm('Are you sure you wish to delete this?');
    });

    // Set "src" attribute on all "img" tags within "a" tags, based on 
    // the rootpath custom attribute.  Also preload the images.
    $("a>img, input[type='image']", scope).each(function ()
    {
        if ($(this).attr("rootpath") != undefined)
        {
            $(this).attr("src", $(this).attr("rootpath") + "Normal.png");
            preLoadImages($(this).attr("rootpath") + "Normal.png");
            preLoadImages($(this).attr("rootpath") + "Hover.png");

            // Create the rollover effects for all image links and buttons.
            $(this).mouseenter(function ()
            {
                $(this).attr("src", $(this).attr("rootpath") + "Hover.png");
            }).mouseleave(
            function ()
            {
                $(this).attr("src", $(this).attr("rootpath") + "Normal.png");
            });
        }
    });

    // Set up safe email links.
    $(".EmailLink", scope).each(function ()
    {
        var emailAddress = '';

        $(this).find("span").each(function ()
        {
            emailAddress = emailAddress + $(this).html();
        });

        $(this).empty();
        $(this).prepend("<a href='mailto:" + emailAddress + "'>" + emailAddress + "</a>");
    });

    $(".Information, .WideInformation, .HelpInformation, .HelpWideInformation, .UrlInformation", scope).each(function ()
    {
        // Make sure we're not inside a repeater template.
        if ($(this).parents(".RepeaterTemplateDiv").length > 0)
        {
            return;
        }

        var html = $(this).html();

        $(this).empty();

        if ($(this).hasClass("HelpInformation") || $(this).hasClass("HelpWideInformation"))
        {
            $(this).append("<img src='/Images/Shared/Icons/HelpLight.gif' />");
        }
        else if ($(this).hasClass("UrlInformation"))
        {
            $(this).append("<img src='/Images/Shared/Icons/Document.gif' />");
        }
        else
        {
            $(this).append("<img src='/Images/Shared/Icons/SmallInfo.gif' />");
        }

        var $calloutDiv =
            $("<div class='CalloutDiv HoverDiv'></div>")
                .appendTo(this)
                .append("<div class='CalloutTopDiv'></div>")
                .append("<div class='CalloutMiddleDiv'>" + html + "</div>")
                .append("<div class='CalloutBottomDiv'></div>");

        if (($(this).hasClass("WideInformation")) || ($(this).hasClass("UrlInformation")) || ($(this).hasClass("HelpWideInformation")))
        {
            $calloutDiv.addClass("CalloutWideDiv");
        }

        $(this).css('display', 'inline');
    });

    $(".HoverDiv", scope).each(function ()
    {
        var hoverDiv = this;
        var $hoverDiv = $(hoverDiv);
        var $hoverParentDiv = $hoverDiv.parent();
        var $hoverRelativeToParentDiv = $hoverDiv.parents(".PositionRelative").first();

        /* Delay the fade-in animation of the tooltip */
        var setTimer = function ()
        {
            // Global variable.
            pendingHover = hoverDiv;

            $hoverParentDiv.showCalloutTimer = setTimeout("displayHoverDiv(pendingHover);", 500);
        }

        var stopTimer = function ()
        {
            clearTimeout($hoverParentDiv.showCalloutTimer);
        }

        $hoverParentDiv.mouseenter(function ()
        {
            setTimer();
        }).mouseleave(
        function ()
        {
            stopTimer();
            $hoverDiv.hide();
        });

        if ($hoverDiv.hasClass("ImagePreviewDiv"))
        {
            $hoverParentDiv.mouseenter(function ()
            {
                $image = $(this).find(".ImagePreviewDiv img");

                // If this is a lazy load img tag, set its src now.
                var lazysrc = $image.attr("lazysrc");

                if ((lazysrc != undefined) && (lazysrc != ""))
                {
                    $image.attr("src", lazysrc);
                    $image.attr("lazysrc", "");
                }
            });
        }
