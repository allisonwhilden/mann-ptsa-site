    $('.InsertLinkButton').click(function ()
    {
        var $insertLinkButton = $(this);
        BrowseForImagesAndLinks("file", $insertLinkButton.attr("data-usevirtualpath") == "True", function (newUrl)
        {
            if (newUrl)
            {
                var insertString = "[[text to display: " + newUrl + "]] ";

                var $textarea = $insertLinkButton.siblings("textarea");
                var cursorPos = $textarea.prop('selectionStart');
                var oldValue = $textarea.val();
                if (textAreaUseMarkdown(oldValue)) {
                    insertString = " [text to display](" + newUrl + ") ";
                }
                var textBefore = oldValue.substring(0, cursorPos);
                var textAfter = oldValue.substring(cursorPos, oldValue.length);
                $textarea.val(textBefore + insertString + textAfter);
                var newCursorPos = cursorPos + insertString.length;
                $textarea.prop('selectionStart', newCursorPos);
                $textarea.prop('selectionEnd', newCursorPos);
                $textarea[0].focus();
            }
        });

        return false;
    });

    $('.InsertImageButton').click(function () {
