---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import Button from '../components/Button.astro';

// 2026–27 board as elected (source: site crawl, July 2026). OPEN = recruiting!
const board = [
  ['Co-Presidents', 'Amy Compton · Bruno Lewin'],
  ['Secretary', 'Jessica Seargeant'],
  ['Co-Treasurers', 'Dave Machaj · Mayur Upalekar'],
  ['Co-VPs of Art', 'Tonya Volegova · Shilpi Sharma'],
  ['Co-VPs of Communications', 'Neha Purohit · OPEN'],
  ['Co-VPs of Enrichment', 'Samatha Mannem · Sucheta Karoor'],
  ['Co-VPs of Volunteers', 'Becca Brown · OPEN'],
  ['Co-VPs of Advocacy', 'OPEN · OPEN'],
  ['Co-VPs of Events', 'OPEN · OPEN'],
  ['Co-VPs of Fundraising', 'OPEN · OPEN'],
];

const committees = [
  ['Enrichment', 'After-school classes, assemblies, math, science fair, book fair'],
  ['Events & Fundraising', 'Back-to-school, dances, movie nights, spirit wear, carnival'],
  ['Art', 'Art docents, Art Night, kiln, NW art project, Reflections'],
  ['School Services', 'Awards, birthday books, hospitality, room leads, Watch DOG'],
];
---

<Base title="About" description="Who we are: the Horace Mann Elementary PTSA — mission, board, committees, meetings, and how to reach us.">
  <PageHero kicker="About us" title="Parents + teachers, organized." dotgrid>
    <p>
      The Horace Mann PTSA (unit 2.8.37) is a 501(c)(3) nonprofit and part of the Washington State
      PTA. Our mission: make every child's potential a reality — at Mann that means funding
      enrichment, backing teachers, and building the kind of community where every Colt belongs.
    </p>
  </PageHero>

  <section class="mx-auto max-w-[1060px] px-6 py-12" id="meetings">
    <div class="grid items-start gap-10 md:grid-cols-2">
      <div>
        <h2 class="mb-4 font-display text-3xl font-extrabold">Meetings</h2>
        <div class="rounded-(--radius-card) border-[3px] border-ink bg-white p-7 shadow-sticker">
          <p class="mb-3 text-[15.5px] text-body-soft">
            <b>General membership meetings</b> happen several times a year, typically 6:00 pm in the
            school library. Every member votes: budget, programs, elections. <b>Board meetings</b>
            alternate months, and meeting recaps are published after each one.
          </p>
          <p class="text-[15.5px] text-body-soft">
            First meeting of 2026–27: <b>[VERIFY date]</b> · Agendas &amp; minutes: <a href="#[VERIFY-minutes-location]" class="font-bold text-brand-dark">meeting documents</a>
          </p>
        </div>
        <h2 class="mt-10 mb-4 font-display text-3xl font-extrabold">Contact</h2>
        <div class="rounded-(--radius-card) border-[3px] border-ink bg-white p-7 shadow-sticker">
          <p class="mb-3 text-[15.5px] text-body-soft">
            [BUILD NOTE: contact form lands here — per-topic routing to the right chair, auto-reply
            with expectations. Until wired:]
          </p>
          <ul class="space-y-1.5 text-[15.5px] font-bold text-brand-dark">
            <li><a href="mailto:volunteers@mannptsa.org">volunteers@mannptsa.org</a> <span class="font-normal text-body-soft">— helping out</span></li>
            <li><a href="mailto:enrichment@mannptsa.org">enrichment@mannptsa.org</a> <span class="font-normal text-body-soft">— classes + financial aid (confidential)</span></li>
            <li><a href="mailto:events@mannptsa.org">events@mannptsa.org</a> <span class="font-normal text-body-soft">— events</span></li>
            <li><a href="mailto:coltconnection@mannptsa.org">coltconnection@mannptsa.org</a> <span class="font-normal text-body-soft">— newsletter</span></li>
          </ul>
          <p class="mt-3 text-sm text-body-soft">
            School office: 17001 NE 104th St, Redmond · Safe arrival: 425-936-2611 [VERIFY]
          </p>
        </div>
      </div>

      <div>
        <h2 class="mb-4 font-display text-3xl font-extrabold">Board 2026–27</h2>
        <p class="mb-4 text-[15.5px] text-body-soft">
          <b class="text-brand-dark">OPEN</b> means you. Several offices are waiting for a
          co-leader — every role can be shared, and outgoing officers train you in.
        </p>
        <div class="overflow-hidden rounded-(--radius-card) border-[3px] border-ink bg-white shadow-sticker">
          {board.map(([role, name], i) => (
            <div class:list={['flex justify-between gap-6 px-6 py-3.5', i !== 0 && 'border-t-2 border-ink/10']}>
              <span class="font-display font-bold">{role}</span>
              <span class="text-body-soft">{name}</span>
            </div>
          ))}
        </div>
        <h2 class="mt-10 mb-4 font-display text-3xl font-extrabold">Committees</h2>
        <div class="space-y-4">
          {committees.map(([name, d]) => (
            <div class="rounded-(--radius-card) border-[3px] border-ink bg-white p-5 shadow-sticker-sm">
              <h3 class="mb-0.5 font-display text-base font-bold">{name}</h3>
              <p class="text-sm text-body-soft">{d}</p>
            </div>
          ))}
        </div>
        <p class="mt-4 text-sm text-body-soft">
          Awards we give: the <b>Golden Acorn</b> (WSPTA) and Mann's own <b>Mannie Award</b>, since 2005.
        </p>
      </div>
    </div>
  </section>
</Base>
