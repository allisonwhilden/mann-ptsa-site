---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import Button from '../components/Button.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Base title="Family directory" description="The Horace Mann PTSA member directory — opt-in, members-only, and how playdates, carpools, and birthday invites actually happen.">
  <PageHero kicker="Members only" title="The directory: how playdates happen." dotgrid>
    <p>
      A private, opt-in directory of Mann families — searchable by student, grade, or teacher, so
      “my kid won't stop talking about Sam in Ms. G's class” turns into a birthday invite.
    </p>
  </PageHero>

  <section class="mx-auto max-w-[860px] px-6 py-12">
    <!-- Launch state: rebuilding + opt-in CTA (the directory data does NOT carry over from the old site) -->
    <div class="relative rounded-(--radius-card) border-[3px] border-ink bg-peach p-8 shadow-sticker">
      <span class="tape" aria-hidden="true"></span>
      <h2 class="mb-2 font-display text-2xl font-extrabold">We're rebuilding the directory for 2026–27 🛠️</h2>
      <p class="mb-5 max-w-[56ch] text-[15.5px] text-body-soft">
        With the new website comes a fresh directory — and for privacy, <b>nobody carries over
        automatically</b>. Every family opts in from scratch when they join. Opt in as you join (or
        any time after), choose exactly which fields to share, and you're in.
      </p>
      <div class="flex flex-wrap gap-4">
        <Button href={`${base}/join/`}>Join + opt in</Button>
        <Button href="#[VERIFY-directory-url]" variant="white">Members: open directory</Button>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-[860px] px-6 pb-16">
    <h2 class="mb-5 font-display text-3xl font-extrabold">The privacy rules (short version)</h2>
    <ul class="space-y-3">
      {[
        ['Opt-in only', 'You appear only if you choose to. No school rosters, no automatic listing — ever.'],
        ['You pick the fields', 'Share your phone but not your address? Just email? Your call, per field.'],
        ['Members only', 'Visible only to current, signed-in PTSA members. Never public, never indexed by search engines.'],
        ['Leave anytime', 'Remove yourself in one step, or email us and we’ll do it fast.'],
        ['Fresh every year', 'The directory resets each school year — graduated families age out automatically.'],
      ].map(([t, d]) => (
        <li class="rounded-(--radius-card) border-[3px] border-ink bg-white p-5 shadow-sticker-sm">
          <h3 class="mb-1 font-display text-base font-bold">{t}</h3>
          <p class="text-[15px] text-body-soft">{d}</p>
        </li>
      ))}
    </ul>
    <p class="mt-5 text-sm text-body-soft">
      Full policy: <a href="#[VERIFY-privacy-policy]" class="font-bold text-brand-dark">Directory privacy policy</a> ·
      Questions or removal requests: <a href="mailto:membership@mannptsa.org" class="font-bold text-brand-dark">membership@mannptsa.org [VERIFY]</a>
    </p>
  </section>
</Base>
