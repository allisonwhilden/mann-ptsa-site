---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import Button from '../components/Button.astro';
import Band from '../components/Band.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

/**
 * Open signups: a simple dated list a board member can edit in one place.
 * Entries auto-hide after their `until` date (design-for-decay).
 */
const signups: { until: string; title: string; when: string; href: string; spots?: string }[] = [
  { until: '2026-09-16', title: 'Back-to-School Night — PTSA table', when: 'Tue Sep 15 · 5:30–7:30 pm', href: '#[VERIFY-signup-url]', spots: 'shifts of 30 min' },
  { until: '2026-09-26', title: 'Movie Night — setup & popcorn crew', when: 'Fri Sep 25 · 4:00–9:00 pm', href: '#[VERIFY-signup-url]' },
];
const today = new Date().toISOString().slice(0, 10);
const open = signups.filter((s) => s.until >= today);

const roles = [
  ['Event helper', '1–3 hours, day-of. Popcorn Popper, Reading Helper, setup crew, face-paint bravery.', 'Zero meetings'],
  ['Classroom volunteer', 'Art Docent, Classroom Lead, or Class Photographer for one classroom.', '~2 hrs/month'],
  ['Event chair', 'Own one event with your VP backing you. Open right now: Movie Night & Silent Auction, Science Fair, Art Night, School Dance, 5th Grade Promotion, Family Fun Night.', '2–6 hrs/month'],
  ['Board member', 'Several 2026–27 offices are OPEN — Events, Fundraising, Advocacy, and co-seats in Communications and Volunteers. Every role can be co-led.', 'varies'],
];
---

<Base title="Volunteer" description="Volunteer at Horace Mann — from a 30-minute popcorn shift to leading a program. No membership required, every bit counts.">
  <PageHero kicker="Volunteering" title="Got an hour? We've got a job." dotgrid>
    <p>
      Volunteering is <b>separate from membership</b> — you don't need to join to help, and joining
      doesn't obligate you to help. Most volunteering is a one-time shift. Start tiny; stay if it's fun.
    </p>
  </PageHero>

  <section class="mx-auto max-w-[1060px] px-6 py-12">
    <h2 class="mb-6 font-display text-3xl font-extrabold">Open signups right now</h2>
    {open.length > 0 ? (
      <div class="space-y-4">
        {open.map((s) => (
          <div class="flex flex-wrap items-center justify-between gap-4 rounded-(--radius-card) border-[3px] border-ink bg-white p-6 shadow-sticker">
            <div>
              <h3 class="font-display text-lg font-bold">{s.title}</h3>
              <p class="text-sm text-body-soft">{s.when}{s.spots && ` · ${s.spots}`}</p>
            </div>
            <Button href={s.href}>Sign up</Button>
          </div>
        ))}
      </div>
    ) : (
      <div class="max-w-md rounded-(--radius-card) border-[3px] border-dashed border-ink/40 bg-white p-6">
        <h3 class="mb-1 font-display text-lg font-bold">Nothing open this week 🐴</h3>
        <p class="text-sm text-body-soft">New signups land here before every event — the newsletter announces them first.</p>
      </div>
    )}
    <p class="mt-4 text-sm text-body-soft">
      Note: helping at school requires an LWSD volunteer application —
      <a href="#[VERIFY-lwsd-volunteer-url]" class="font-bold text-brand-dark">apply here</a> (takes ~10 minutes, renews every two years).
      Middle/high-school students can volunteer too via the student application — great for service hours.
    </p>
  </section>

  <section class="mx-auto max-w-[1060px] px-6 pb-12">
    <h2 class="mb-6 font-display text-3xl font-extrabold">Ways to plug in</h2>
    <div class="grid gap-6 md:grid-cols-2">
      {roles.map(([title, d, time]) => (
        <div class="rounded-(--radius-card) border-[3px] border-ink bg-white p-6 shadow-sticker">
          <div class="mb-1 flex items-center justify-between gap-4">
            <h3 class="font-display text-lg font-bold">{title}</h3>
            <span class="rounded-full border-2 border-ink bg-peach px-3 py-0.5 text-xs font-extrabold">{time}</span>
          </div>
          <p class="text-[15px] text-body-soft">{d}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="mx-auto max-w-[1060px] px-6 pb-16">
    <Band>
      <Fragment slot="title">Not sure where you fit?</Fragment>
      Tell us what you're good at (or want to try) and how much time you have — we'll match you.
      <Button slot="action" href="mailto:volunteers@mannptsa.org" variant="white">volunteers@mannptsa.org</Button>
    </Band>
  </section>
</Base>
