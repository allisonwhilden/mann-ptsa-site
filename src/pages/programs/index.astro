---
import Base from '../../layouts/Base.astro';
import PageHero from '../../components/PageHero.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const programs = [
  { href: '/programs/enrichment/', emoji: '🎻', title: 'Enrichment & Music', d: 'After-school classes in sports, arts, and STEM — plus yearlong choir, band, and orchestra.' },
  { href: '/programs/arts/', emoji: '🎨', title: 'Art Program', d: 'Art docents in every classroom, kiln projects, Reflections, and visiting artists.' },
  { href: '/programs/math/', emoji: '🔢', title: 'Math Club', d: 'Math nights, challenges, and competitive teams — with financial help so everyone can play.' },
  { href: '/programs/science-fair/', emoji: '🧪', title: 'Science Fair', d: 'Every student a scientist for a night, every February.' },
  { href: '/programs/school-life/', emoji: '📚', title: 'School Life', d: 'Yearbook, spirit wear, Birthday Book Club, and staff appreciation.' },
];
---

<Base title="Programs" description="Everything the Horace Mann PTSA runs: after-school enrichment and music, art, math club, science fair, yearbook, and more.">
  <PageHero kicker="Programs" title="What your PTSA runs." dotgrid>
    <p>
      Every one of these is powered by volunteers and funded by memberships and the Colt Corral.
      Most have a way in for your kid — and a way to help for you.
    </p>
  </PageHero>

  <section class="mx-auto max-w-[1060px] px-6 py-12">
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {programs.map((p) => (
        <a href={`${base}${p.href}`} class="block rounded-(--radius-card) border-[3px] border-ink bg-white p-6 no-underline shadow-sticker transition-transform duration-75 hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-sticker-sm">
          <span class="text-3xl" aria-hidden="true">{p.emoji}</span>
          <h2 class="mt-2 mb-1 font-display text-xl font-bold text-ink">{p.title}</h2>
          <p class="text-[15px] text-body-soft">{p.d}</p>
        </a>
      ))}
    </div>
  </section>
</Base>
