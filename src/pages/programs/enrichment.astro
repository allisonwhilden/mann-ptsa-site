---
import Base from '../../layouts/Base.astro';
import PageHero from '../../components/PageHero.astro';
import Button from '../../components/Button.astro';

const sessions = [
  ['Fall 2026', 'Enrollment Sep 6 (6 pm) – Sep 28 · classes Sep 28 – Dec 11 (9–10 weeks)'],
  ['Winter 2027', 'Enrollment opens Dec 14 – Jan 5 · classes run winter term [VERIFY exact dates]'],
  ['Spring 2027', 'Enrollment announced in the newsletter [VERIFY dates]'],
];
---

<Base title="Enrichment & music" description="After-school enrichment at Horace Mann: sports, arts, and STEM classes in three sessions, plus yearlong choir, band, and orchestra.">
  <PageHero kicker="Programs · Enrichment" title="After school, but the fun kind." dotgrid>
    <p>
      Sports, arts, music, and STEM classes right on campus after the bell — three sessions a
      year, taught by vetted providers, organized entirely by PTSA volunteers.
      <b>PTSA members get early registration access</b> — classes fill fast.
    </p>
  </PageHero>

  <section class="mx-auto max-w-[860px] px-6 py-12">
    <h2 class="mb-5 font-display text-3xl font-extrabold">Session schedule</h2>
    <div class="overflow-hidden rounded-(--radius-card) border-[3px] border-ink bg-white shadow-sticker">
      {sessions.map(([when, what], i) => (
        <div class:list={['flex flex-wrap gap-x-6 gap-y-1 px-6 py-4', i !== 0 && 'border-t-2 border-ink/10']}>
          <span class="w-28 shrink-0 font-display font-extrabold text-brand-dark">{when}</span>
          <span class="text-[15.5px] text-body-soft">{what}</span>
        </div>
      ))}
    </div>
    <div class="mt-6">
      <Button href="#[VERIFY-enrichment-registration-url]">Browse & register for classes</Button>
    </div>
  </section>

  <section class="mx-auto max-w-[860px] px-6 pb-12">
    <h2 class="mb-5 font-display text-3xl font-extrabold">Music: choir, band & orchestra 🎺</h2>
    <div class="space-y-5 rounded-(--radius-card) border-[3px] border-ink bg-white p-7 shadow-sticker">
      <p class="text-[15.5px] text-body-soft">
        Unlike other enrichment classes, music runs the <b>full school year</b>. Enrollment opens
        with fall enrichment; <b>choir stays open all year</b> — join any time. Band & Orchestra
        Information Night is in late September [VERIFY 2026 date] in the gym: students try
        instruments, get measured, and families can arrange rentals on the spot.
      </p>
      <p class="text-[15.5px] text-body-soft">
        <b>Instruments:</b> families provide their own instrument, stand, and book. Music &amp;
        Arts in Redmond (16611 Redmond Way, 425-881-8777) offers a Horace Mann rental deal —
        mention the school ($5 first month, then ~$28/month [VERIFY current pricing]).
      </p>
      <div class="rounded-xl border-2 border-ink bg-peach p-4 text-[15px] text-body-soft">
        💛 <b>Cost should never keep a kid out of music.</b> If renting is hard for your family
        right now, email <a href="mailto:enrichment@mannptsa.org" class="font-bold text-brand-dark">enrichment@mannptsa.org</a>
        (confidential) — volunteers will help find a free loaner instrument. The same goes for any
        enrichment class: financial aid is quietly available.
      </div>
    </div>
  </section>
</Base>
