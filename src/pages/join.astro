---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import Button from '../components/Button.astro';
import Band from '../components/Band.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const tiers = [
  { name: 'Individual', price: '$[VERIFY]', d: 'One adult. Full voting membership.' },
  { name: 'Dual', price: '$[VERIFY]', d: 'Two adults in the same family (same household not required). Two votes.' },
  { name: 'Staff', price: '$[VERIFY]', d: 'Horace Mann staff — we would love to have you.' },
];

const perks = [
  'Early access to after-school enrichment class registration — they fill fast [VERIFY perk carries into 2026–27]',
  'Access to the family directory (opt-in) — playdates and carpools, unlocked',
  'A vote at general membership meetings on budget, programs, and elections',
  'WSPTA member discounts — car rentals, theme parks, printing, and more',
  'First access to in-school volunteering opportunities + the newsletter',
];
---

<Base title="Join" description="Join the Horace Mann PTSA — two minutes online, open to everyone, and every membership funds programs kids love.">
  <PageHero kicker="Membership 2026–27" title="Two minutes. A whole year of good." dotgrid>
    <p>
      Membership is open to <b>everyone</b> — parents, guardians, grandparents, staff, and
      neighbors, regardless of citizenship or residency status. Joining never signs you up to
      volunteer. It just makes the good stuff possible.
    </p>
  </PageHero>

  <section class="mx-auto max-w-[1060px] px-6 py-12">
    <div class="grid gap-6 md:grid-cols-3">
      {tiers.map((t) => (
        <div class="rounded-(--radius-card) border-[3px] border-ink bg-white p-7 shadow-sticker">
          <h2 class="font-display text-xl font-bold">{t.name}</h2>
          <p class="my-2 font-display text-4xl font-extrabold text-brand">{t.price}</p>
          <p class="text-[15px] text-body-soft">{t.d}</p>
        </div>
      ))}
    </div>
    <p class="mt-4 text-sm text-body-soft">
      Memberships run per school year and renew each fall. Cost should never be a barrier —
      email <a href="mailto:membership@mannptsa.org" class="font-bold text-brand-dark">membership@mannptsa.org [VERIFY address]</a> and we'll quietly sort it out.
    </p>
  </section>

  <section class="mx-auto max-w-[1060px] px-6 pb-12">
    <div class="grid items-start gap-10 md:grid-cols-2">
      <div>
        <h2 class="mb-4 font-display text-3xl font-extrabold">What members get</h2>
        <ul class="space-y-3">
          {perks.map((p) => (
            <li class="flex gap-3 text-[15.5px] text-body-soft">
              <span class="mt-0.5 font-extrabold text-brand">★</span>
              <span>{p}</span>
            </li>
          ))}
        </ul>
      </div>
      <div class="rounded-(--radius-card) border-[3px] border-ink bg-white p-7 shadow-sticker">
        <h2 class="mb-3 font-display text-xl font-bold">How joining works</h2>
        <ol class="list-decimal space-y-2 pl-5 text-[15.5px] text-body-soft">
          <li>Tap the button below — checkout opens on <b>Givebacks</b>, our membership partner (it's also Washington State PTA's official system).</li>
          <li>Pick your membership, pay online, done.</li>
          <li>Your e-membership card arrives by email; keep it for WSPTA discounts.</li>
          <li>Renewing next year takes one minute — same place, same login.</li>
        </ol>
        <div class="mt-5">
          <Button href="#[VERIFY-givebacks-store-url]">Join on Givebacks</Button>
        </div>
        <p class="mt-3 text-xs text-body-soft">Prefer paper or cash? Forms are available at the front office. [VERIFY]</p>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-[1060px] px-6 pb-16">
    <Band>
      <Fragment slot="title">Already a member? You're the reason this works.</Fragment>
      Check what's coming up, opt into the directory, or grab a volunteer shift — whatever fits
      your season.
      <Button slot="action" href={`${base}/volunteer/`} variant="white">See volunteer shifts</Button>
    </Band>
  </section>
</Base>
