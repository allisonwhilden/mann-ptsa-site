---
import Button from './Button.astro';

const links = [
  { href: '/start-here/', label: 'Start Here' },
  { href: '/events/', label: 'Events' },
  { href: '/volunteer/', label: 'Volunteer' },
  { href: '/give/', label: 'Give' },
  { href: '/directory/', label: 'Directory' },
  { href: '/about/', label: 'About' },
];
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const current = Astro.url.pathname;
---

<nav class="border-b-[3px] border-ink bg-paper">
  <div class="mx-auto flex max-w-[1060px] items-center gap-5 px-6 py-4">
    <a href={`${base}/`} class="flex items-center gap-2.5 font-display text-[21px] font-extrabold text-ink no-underline">
      <span class="-rotate-4 rounded-xl border-[3px] border-ink bg-brand px-2.5 py-0.5 text-white shadow-[3px_3px_0_var(--color-ink)]">GO&nbsp;COLTS</span>
      <span>Mann&nbsp;PTSA</span>
    </a>

    <div class="ml-auto hidden items-center gap-5 lg:flex">
      {links.map(({ href, label }) => (
        <a
          href={`${base}${href}`}
          aria-current={current === `${base}${href}` ? 'page' : undefined}
          class:list={[
            'border-b-[3px] text-[15px] font-extrabold text-ink no-underline hover:border-brand',
            current === `${base}${href}` ? 'border-brand' : 'border-transparent',
          ]}
        >
          {label}
        </a>
      ))}
    </div>
    <div class="ml-auto lg:ml-0">
      <Button href={`${base}/join/`}>Join!</Button>
    </div>

    <details class="relative lg:hidden">
      <summary class="grid h-11 w-11 cursor-pointer list-none place-items-center rounded-xl border-[3px] border-ink bg-white shadow-sticker-sm [&::-webkit-details-marker]:hidden" aria-label="Menu">
        <span class="font-extrabold">☰</span>
      </summary>
      <div class="absolute right-0 z-50 mt-2 w-56 rounded-(--radius-card) border-[3px] border-ink bg-white p-3 shadow-sticker">
        {links.map(({ href, label }) => (
          <a href={`${base}${href}`} class="block rounded-lg px-3 py-2.5 font-extrabold text-ink no-underline hover:bg-peach">
            {label}
          </a>
        ))}
      </div>
    </details>
  </div>
</nav>
