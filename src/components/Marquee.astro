---
/** Announcement ribbon. Items render as a static repeating strip (no motion). */
interface Props {
  items: string[];
}
const { items } = Astro.props;
const doubled = [...items, ...items];
---

<div class="overflow-hidden border-y-[3px] border-ink bg-brand-dark py-[11px] font-display text-[16.5px] font-bold whitespace-nowrap text-white" aria-hidden="true">
  {doubled.map((item) => <span class="mx-[22px]">★ {item}</span>)}
</div>
